###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_this_secret_in_production_min_32_chars
###< symfony/framework-bundle ###

###> MySQL Configuration for Docker ###
MYSQL_ROOT_PASSWORD=change_me_strong_password
MYSQL_DATABASE=rings_catalog
MYSQL_USER=rings_user
MYSQL_PASSWORD=change_me_strong_password
MYSQL_PORT=3307
###< MySQL Configuration for Docker ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://rings_user:change_me_strong_password@mysql:3306/rings_catalog?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=your_jwt_passphrase_change_in_production
JWT_TOKEN_TTL=3600
###< lexik/jwt-authentication-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailhog:1025
###< symfony/mailer ###

###> redis ###
REDIS_URL=redis://redis:6379
###< redis ###

# Admin email для уведомлений
ADMIN_EMAIL=your_email@example.com

# Домен сайта
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# CORS Origins - разрешаем localhost на любых портах для разработки
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

###> symfony/routing ###
DEFAULT_URI=http://localhost:8000
###< symfony/routing ###

###> nelmio/cors-bundle ###
# Разрешаем CORS для localhost на всех портах (для разработки)
# В продакшене замените на конкретный домен
###< nelmio/cors-bundle ###
